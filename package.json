{
  "name": "@spawn-dock/mcp",
  "version": "1.0.0",
  "description": "MCP client for SpawnDock knowledge server — stdio-to-SSE bridge for AI agents",
  "type": "module",
  "bin": {
    "spawn-dock-mcp": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/index.js",
    "lint": "eslint .",
    "test": "vitest run",
    "check": "npm run lint && npm run build && npm run test"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "zod": "^4.3.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@types/node": "^25.0.0",
    "eslint": "^9.0.0",
    "typescript": "^5.9.0",
    "typescript-eslint": "^8.0.0",
    "vitest": "^3.0.0"
  },
  "keywords": [
    "mcp",
    "spawndock",
    "telegram-mini-app",
    "tma",
    "knowledge-base",
    "ai-agent"
  ],
  "license": "MIT",
  "homepage": "https://github.com/SpawnDock/mcp-client#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/SpawnDock/mcp-client.git"
  },
  "bugs": {
    "url": "https://github.com/SpawnDock/mcp-client/issues"
  }
}
